## This file is automatically generated by Android Studio.
# Do not modify this file -- YOUR CHANGES WILL BE ERASED!
#
# This file should *NOT* be checked into Version Control Systems,
# as it contains information specific to your local configuration.
#
# Location of the SDK. This is only used by Gradle.
# For customization when using a Version Control System, please read the
# header note.
#
# 如何找到 sdk.dir 路径：
# 1. 打开 Android Studio → File → Settings → Appearance & Behavior → System Settings → Android SDK
# 2. 查看页面顶部的 "Android SDK Location" 字段
# 3. Windows 默认路径：C:\Users\<你的用户名>\AppData\Local\Android\Sdk
# 4. 注意：Windows 路径中的反斜杠需要转义为双反斜杠（\\）
sdk.dir=/path/to/your/Android/Sdk

# ── API Keys ──
# DashScope 语音识别 API Key（必填）
# 申请地址：https://dashscope.console.aliyun.com/ → API-KEY 管理
DASHSCOPE_API_KEY=

# ── OpenClaw Agent Gateway ────────────────────────────────────────────────────
# Base URL of your OpenClaw server (include port, no trailing slash)
OPENCLAW_BASE_URL=http://192.168.x.x:18789

# Gateway authentication token
OPENCLAW_GATEWAY_TOKEN=your-gateway-token-here

# Agent ID to route requests to (default: main)
OPENCLAW_AGENT_ID=main

# ── Release Signing ──────────────────────────────────────────────────────────
# Keystore 文件路径（相对于项目根目录）
KEYSTORE_FILE=rayclaw-release.keystore

# Keystore 密码
KEYSTORE_PASSWORD=your_keystore_password

# Key 别名
KEY_ALIAS=rayclaw

# Key 密码
KEY_PASSWORD=your_key_password
