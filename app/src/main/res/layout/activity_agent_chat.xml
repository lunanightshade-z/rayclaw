<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#020202">

    <!--
        Color theme: Obsidian + Jade
        ─ Near-pure black (#020202) → on waveguide = near-transparent, maximises AR contrast
        ─ Jade green accent (#00C896) → vibrant, non-blue, reads clearly on AR
        ─ Warm ivory text (#EEE8DC)  → softer than pure white, easier for eyes

        Gestures:
          单击          → 开始/暂停对话
          上划 / 下划   → 上下滚动 AI 回复
          三击          → 打开设置（语言 / 监听模式 / 重置对话）
          双击          → 退出

        NOTE: LongClick deliberately avoided — triggers system WiFi/settings panel.
              DoubleFingerClick not used — physically impractical on narrow X3 temple pad.
    -->

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.22" />

    <!-- ═══════════════════ TOP BAR ═══════════════════ -->

    <!-- Language / ASR badge — jade accent -->
    <TextView
        android:id="@+id/tvLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="10dp"
        android:background="#1500C896"
        android:paddingHorizontal="11dp"
        android:paddingVertical="5dp"
        android:text="语音: 中文"
        android:textColor="#00C896"
        android:textSize="13sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Agent provider badge -->
    <TextView
        android:id="@+id/tvProvider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="10dp"
        android:background="#0EFFFFFF"
        android:paddingHorizontal="9dp"
        android:paddingVertical="5dp"
        android:text="OpenClaw"
        android:textColor="#484840"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status — color set in Kotlin (idle/listening/thinking/error) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="单击镜腿开始对话"
        android:textColor="#383830"
        android:textSize="13sp"
        app:layout_constraintEnd_toStartOf="@id/tvProvider"
        app:layout_constraintStart_toEndOf="@id/tvLanguage"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top divider -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#161614"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus" />

    <!-- ═══════════════════ SIDEBAR ═══════════════════ -->

    <!-- Sidebar fill — very slightly lighter than root black -->
    <View
        android:id="@+id/sidebarBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#080806"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- "会话" section label -->
    <TextView
        android:id="@+id/tvSidebarLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp"
        android:letterSpacing="0.14"
        android:text="会话"
        android:textColor="#282820"
        android:textSize="11sp"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- Current session indicator (text + color set in Kotlin) -->
    <TextView
        android:id="@+id/tvSessions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:gravity="top|start"
        android:lineSpacingMultiplier="1.65"
        android:textColor="#303028"
        android:textSize="13sp"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSidebarLabel" />

    <!-- ═══════════════════ VERTICAL DIVIDER ═══════════════════ -->

    <View
        android:id="@+id/dividerV"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#161614"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintStart_toEndOf="@id/guidelineV"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- ═══════════════════ MAIN CHAT AREA ═══════════════════ -->

    <!-- User speech bubble (text + color set in Kotlin) -->
    <TextView
        android:id="@+id/tvUserInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_user_bubble"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.4"
        android:maxLines="3"
        android:paddingHorizontal="16dp"
        android:paddingVertical="12dp"
        android:textColor="#181816"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dividerV"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- AI response WebView (Markdown rendered) -->
    <WebView
        android:id="@+id/wvResponse"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@android:color/transparent"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dividerV"
        app:layout_constraintTop_toBottomOf="@id/tvUserInput" />

    <!-- ═══════════════════ BOTTOM HINT BAR ═══════════════════ -->

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="单击: 对话  上/下划: 滚动  三击: 设置  双击: 退出"
        android:textColor="#242420"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
