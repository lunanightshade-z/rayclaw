<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080A14">

    <!--
        Layout: ChatGPT-style AR interface
        ┌──────────┬─────────────────────────────────────┐
        │ [lang]   │  [status]              [provider]   │  ← top bar
        ├──────────┼─────────────────────────────────────┤
        │          │                                     │
        │ 会话     │  [User speech bubble]               │
        │          │  ─────────────────────────────────  │
        │ ● 当前   │  [AI Response WebView]              │
        │   对话   │                                     │
        │   N 轮   │                                     │
        ├──────────┴─────────────────────────────────────┤
        │              [gesture hints]                    │  ← bottom bar
        └─────────────────────────────────────────────────┘
        Sidebar: 22% | Main chat: 78%
    -->

    <!-- Vertical guideline: sidebar ends / main chat begins -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guidelineV"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.22" />

    <!-- ═══════════════════ TOP BAR ═══════════════════ -->

    <!-- Language / ASR badge (left) -->
    <TextView
        android:id="@+id/tvLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="14dp"
        android:layout_marginTop="10dp"
        android:background="#1A3B9EFF"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="语音: 中文"
        android:textColor="#3B9EFF"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Agent provider badge (right) -->
    <TextView
        android:id="@+id/tvProvider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="14dp"
        android:layout_marginTop="10dp"
        android:background="#08FFFFFF"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:text="OpenClaw"
        android:textColor="#1E2D4A"
        android:textSize="11sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Status indicator (centered) -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:text="单击镜腿开始对话"
        android:textColor="#1E2D4A"
        android:textSize="12sp"
        app:layout_constraintEnd_toStartOf="@id/tvProvider"
        app:layout_constraintStart_toEndOf="@id/tvLanguage"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Top horizontal divider -->
    <View
        android:id="@+id/dividerTop"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_marginTop="8dp"
        android:background="#151D35"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvStatus" />

    <!-- ═══════════════════ SIDEBAR PANEL ═══════════════════ -->

    <!-- Sidebar dark background -->
    <View
        android:id="@+id/sidebarBg"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#0B0D1C"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- Sidebar section label -->
    <TextView
        android:id="@+id/tvSidebarLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginTop="14dp"
        android:letterSpacing="0.12"
        android:text="会话"
        android:textColor="#1A2840"
        android:textSize="10sp"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- Session list — shows current conversation indicator -->
    <TextView
        android:id="@+id/tvSessions"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="6dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="4dp"
        android:layout_marginBottom="8dp"
        android:gravity="top|start"
        android:lineSpacingMultiplier="1.6"
        android:textColor="#243450"
        android:textSize="12sp"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toStartOf="@id/guidelineV"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvSidebarLabel" />

    <!-- ═══════════════════ VERTICAL DIVIDER ═══════════════════ -->

    <View
        android:id="@+id/dividerV"
        android:layout_width="1dp"
        android:layout_height="0dp"
        android:background="#151D35"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintStart_toEndOf="@id/guidelineV"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- ═══════════════════ MAIN CHAT AREA ═══════════════════ -->

    <!-- User speech input (displays recognized speech text) -->
    <TextView
        android:id="@+id/tvUserInput"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:layout_marginTop="14dp"
        android:layout_marginEnd="16dp"
        android:background="@drawable/bg_user_bubble"
        android:ellipsize="end"
        android:lineSpacingMultiplier="1.3"
        android:maxLines="3"
        android:paddingHorizontal="14dp"
        android:paddingVertical="10dp"
        android:textColor="#243450"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dividerV"
        app:layout_constraintTop_toBottomOf="@id/dividerTop" />

    <!-- AI agent response (rendered Markdown via WebView) -->
    <WebView
        android:id="@+id/wvResponse"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp"
        android:background="@android:color/transparent"
        android:overScrollMode="never"
        app:layout_constraintBottom_toTopOf="@id/tvHint"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/dividerV"
        app:layout_constraintTop_toBottomOf="@id/tvUserInput" />

    <!-- ═══════════════════ BOTTOM HINT BAR ═══════════════════ -->

    <TextView
        android:id="@+id/tvHint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:gravity="center"
        android:text="单击: 开始/暂停  前后滑: 切换语言  长按: 清空  双击: 退出"
        android:textColor="#0F1828"
        android:textSize="10sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
