<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- 录音权限（语音识别必须） -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <!-- 网络权限（Agent API 调用） -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!--
        usesCleartextTraffic is intentionally true: the OpenClaw gateway URL is
        user-configurable at runtime (rayclaw.conf) and may point to a self-hosted
        HTTP server on a local network. Remove this flag if your deployment uses HTTPS only.
    -->
    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.RayClaw">

        <!-- 让眼镜 Launcher 识别此应用 -->
        <meta-data
            android:name="com.rayneo.mercury.app"
            android:value="true" />

        <activity
            android:name=".AgentChatActivity"
            android:exported="true"
            android:screenOrientation="landscape">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
